{
  "manifest_version": 3,
  "name": "__MSG_ext_name__",
  "version": "1.0.0",
  "description": "__MSG_ext_description__",
  "default_locale": "en",
  "permissions": [
    "tabs",
    "tabGroups",
    "bookmarks",
    "storage",
    "sessions",
    "contextMenus",
    "activeTab",
    "sidePanel"
  ],
  "host_permissions": [],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "__MSG_ext_action_title__",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "navigate-tab-next": {
      "suggested_key": {
        "default": "Alt+Shift+Right",
        "mac": "Alt+Shift+Right"
      },
      "description": "__MSG_cmd_next_tab__"
    },
    "navigate-tab-prev": {
      "suggested_key": {
        "default": "Alt+Shift+Left",
        "mac": "Alt+Shift+Left"
      },
      "description": "__MSG_cmd_prev_tab__"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
