{
  "manifest_version": 3,
  "name": "TabPlusPlus",
  "version": "1.0.0",
  "description": "智能一体化的Tab管理插件 - Smart all-in-one tab management extension",
  "permissions": [
    "tabs",
    "bookmarks",
    "storage",
    "sessions",
    "contextMenus",
    "activeTab",
    "sidePanel"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TabPlusPlus",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
